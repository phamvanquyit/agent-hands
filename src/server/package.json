{
  "name": "agent-hands-server",
  "version": "1.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "NODE_OPTIONS=\"--max-old-space-size=8192\" bunx tsc --noEmit",
    "dev": "bun --watch src/index.ts",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bun src/common/db/migrate.ts",
    "test": "bun test src/",
    "test:files": "bun test src/modules/storage/files.test.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/google": "^3.0.75",
    "@ai-sdk/openai": "^3.0.64",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@types/turndown": "^5.0.6",
    "ai": "^6.0.184",
    "cloakbrowser": "^0.3.31",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.3.2",
    "fastify-type-provider-zod": "^4.0.2",
    "jose": "^6.0.10",
    "nanoid": "^5.1.5",
    "playwright-core": "^1.60.0",
    "turndown": "^7.2.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
